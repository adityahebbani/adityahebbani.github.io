---
import Layout from "@/src/layouts/Layout.astro";
import Header from "@/src/components/Header.astro";
import Footer from "@/src/components/Footer.astro";

import content from "@/src/content/site.json";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const nav = [
	{ href: `/#${content.nav.about}`, text: content.nav.about },
	{ href: `/#${content.nav.experience}`, text: content.nav.experience },
	{ href: `/#${content.nav.projects}`, text: content.nav.projects },
	{ href: `/blog`, text: content.nav.blog ?? "blog" },
	{ href: `/#${content.nav.contact}`, text: content.nav.contact },
];
---

<Layout locale="en" siteName={content.hero.name} title={`${content.hero.name} — Blog`} description={content.description}>
	<Header nav={nav} />

	<main class="mt-50">
		<section class="mb-10">
			<h1 class="mb-2 font-semibold text-xl">Blog</h1>
			<p class="opacity-50">Writing about building and shipping software.</p>
		</section>

		<section class="grid gap-6">
			{posts.map((post) => (
				<article class="border border-border rounded-lg p-5">
					<a class="block" href={`/blog/${post.slug}`}>
						<h2 class="font-semibold opacity-90 hover:opacity-100 transition-opacity">
							{post.data.title}
						</h2>
					</a>
					{post.data.description && (
						<p class="opacity-50 mt-2">{post.data.description}</p>
					)}
					<p class="opacity-50 mt-3 text-sm">
						{post.data.pubDate.toLocaleDateString("en", {
							year: "numeric",
							month: "short",
							day: "2-digit",
						})}
					</p>
				</article>
			))}
		</section>
	</main>

	<Footer
		id={content.nav.contact}
		status={content.contact.status}
		email_label={content.contact.email_label}
		email_url={content.contact.email_url}
		github_label={content.contact.github_label}
		github_url={content.contact.github_url}
		x_label={content.contact.x_label}
		x_url={content.contact.x_url}
		linkedin_label={content.contact.linkedin_label}
		linkedin_url={content.contact.linkedin_url}
	/>
</Layout>
